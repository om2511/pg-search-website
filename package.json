{
  "name": "pg-search-website",
  "version": "1.0.0",
  "description": "Full-stack MERN application for PG accommodation search and management",
  "main": "server/server.js",
  "scripts": {
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "seed": "cd server && npm run seed",
    "start": "cd server && npm start",
    "setup": "chmod +x setup.sh && ./setup.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/pg-search-website.git"
  },
  "keywords": [
    "MERN",
    "React",
    "Node.js",
    "MongoDB",
    "Express",
    "PG",
    "Accommodation",
    "Rental",
    "Real Estate"
  ],
  "author": "Om Prajapati",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}